# --- TripMind Backend Configuration ---

# App Environment
APP_ENV=development
DEBUG=True

# Supabase Configuration
# Didapatkan dari: Project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-service-role-key-here

# Google Maps Platform
# Digunakan untuk: Distance Matrix & Places API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Google Cloud / Vertex AI
# Digunakan untuk: Gemini AI Orchestration
GOOGLE_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/service-account.json

# Database Connection (Optional for direct SQL)
DATABASE_URL=postgresql://postgres:password@db.your-id.supabase.co:5432/postgres